/* USER CODE BEGIN PV */

// Variables to track button presses and LED states

//volatile is used because these variables are modified in the interrupt callback and read in the main loop

volatile uint8_t button0_pressed = 0;
volatile uint8_t button1_pressed = 0;

uint8_t led0_blinking = 0;
uint8_t led1_blinking = 0;
uint8_t led0_toggles = 0;
uint8_t led1_toggles = 0;
uint32_t led0_last_tick = 0;
uint32_t led1_last_tick = 0;

/* USER CODE END PV */

/* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)


     
  {

    uint32_t now = HAL_GetTick();

    // Start blink sequence when button pressed
    if (button0_pressed)
    {
        button0_pressed = 0;
        led0_blinking = 1;
        led0_toggles = 0;
        led0_last_tick = now;
    }

    if (button1_pressed)
    {
        button1_pressed = 0;
        led1_blinking = 1;
        led1_toggles = 0;
        led1_last_tick = now;
    }

    // Handle LED0 blinking (PA4)
    if (led0_blinking && (now - led0_last_tick >= 500))
    {
        HAL_GPIO_TogglePin(GPIOA, GPIO_PIN_4);
        led0_last_tick = now;
        led0_toggles++;
        if (led0_toggles >= 10)
        {
            led0_blinking = 0;
            HAL_GPIO_WritePin(GPIOA, GPIO_PIN_4, GPIO_PIN_RESET);
        }
    }

    // Handle LED1 blinking (PB0)
    if (led1_blinking && (now - led1_last_tick >= 500))
    {
        HAL_GPIO_TogglePin(GPIOB, GPIO_PIN_0);
        led1_last_tick = now;
        led1_toggles++;
        if (led1_toggles >= 10)
        {
            led1_blinking = 0;
            HAL_GPIO_WritePin(GPIOB, GPIO_PIN_0, GPIO_PIN_RESET);
        }
    }

   
  }
    /* USER CODE END WHILE */



/* USER CODE BEGIN 4 */

// EXTI line0 and line1 interrupt callback

  void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin)
{
    if (GPIO_Pin == GPIO_PIN_0)
    {
        button0_pressed = 1;
    }
    else if (GPIO_Pin == GPIO_PIN_1)
    {
        button1_pressed = 1;
    }
}


/* USER CODE END 4 */


    


















